  "keyFeatures": [
    "End-to-end autonomous coding pipeline from task to PR",
    "Two-tier LLM architecture with Goose agent for coding and Claude CLI for text generation",
    "Blueprint engine with deterministic Shell steps and AI Agent steps",
    "Task classification (Simple/Standard/BugFix) with blueprint selection",
    "Built-in TDD and diagnostic blueprints for feature development and bug fixes",
    "CI loop with automatic lint, test, and fix retries",
    "Multi-platform chat adapters (Discord, Teams, CLI)",
    "Org-scoped repo resolution for multi-repository workflows",
    "Sandbox abstraction with local and Daytona support",
    "Plane integration for issue tracking",
    "JSONL tracing and observability",
    "Git operations with collision handling and PR automation"
  ],
  "publicApiSurface": [
    "run_pipeline() - Main pipeline orchestrator",
    "MagpieAgent - Goose agent wrapper for coding tasks",
    "BlueprintRunner - Executes blueprints with Shell and Agent steps",
    "ChatPlatform trait - Implement for custom chat adapters",
    "Sandbox trait - Implement for custom sandbox backends",
    "GitOps - Git operations (branch, commit, push, PR)",
    "PlaneClient - Plane issue tracker integration",
    "classify_task() - Classify task complexity",
    "build_main_blueprint() - Simple single-shot agent blueprint",
    "build_tdd_blueprint() - TDD blueprint for features",
    "build_diagnostic_blueprint() - Diagnostic blueprint for bug fixes",
    "build_fix_blueprint() - Fix blueprint for CI failures",
    "LocalSandbox - Local command execution sandbox",
    "DaytonaSandbox - Daytona remote sandbox",
    "clone_repo() - Org-scoped repo resolution and cloning",
    "TraceBuilder - Agent call tracing and observability"
  ]
}
